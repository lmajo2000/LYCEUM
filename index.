<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>사고독서 리세움 | 국어 기반 사고문해력 교육원</title>
<link href="https://fonts.googleapis.com/css2?family=Gowun+Batang:wght@400;700&family=Noto+Sans+KR:wght@300;400;500;700;900&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,700;1,300;1,400&family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&display=swap" rel="stylesheet" />
<style>
/* ===== Base ===== */
* { margin:0; padding:0; box-sizing:border-box; }
html { scroll-behavior:smooth; }
body {
  font-family:'Noto Sans KR', sans-serif;
  color:#1f2a20; background:#fff;
  line-height:1.9; letter-spacing:-0.2px;
  -webkit-font-smoothing:antialiased;
}
h1,h2,h3,h4 { font-family:'Gowun Batang', serif; line-height:1.5; letter-spacing:-0.5px; }
a { color:inherit; text-decoration:none; }
img { max-width:100%; display:block; }

/* ===== Layout ===== */
.container { max-width:1140px; margin:0 auto; padding:0 24px; position:relative; z-index:2; }
section { padding:130px 0; position:relative; overflow:hidden; }
.section-label {
  display:inline-block; font-family:'Playfair Display', serif;
  font-size:13px; letter-spacing:6px; font-weight:700;
  margin-bottom:24px; text-transform:uppercase;
  padding:8px 20px; border-radius:25px;
}
.section-title { font-size:44px; margin-bottom:28px; font-weight:700; line-height:1.55; }
.section-desc { font-size:17px; margin-bottom:70px; max-width:760px; line-height:2; }

/* ===== Watermark ===== */
.watermark {
  position:absolute; font-family:'Playfair Display', serif;
  font-weight:900; font-style:italic;
  pointer-events:none; user-select:none;
  z-index:1; letter-spacing:-5px;
}

/* ===== Header ===== */
header {
  position:fixed; top:0; left:0; right:0;
  background:rgba(255,255,255,0.97);
  backdrop-filter:blur(12px); z-index:1000;
  border-bottom:2px solid #2c4a2d;
  box-shadow:0 2px 15px rgba(0,0,0,0.05);
}
.nav { display:flex; justify-content:space-between; align-items:center; padding:16px 0; }
.logo { font-family:'Gowun Batang', serif; font-size:24px; font-weight:700; color:#2c4a2d; }
.logo span {
  font-family:'Cormorant Garamond', serif; color:#6b8e5a;
  font-weight:400; font-style:italic;
  font-size:15px; margin-left:8px; letter-spacing:3px;
}
.nav-menu { display:flex; gap:38px; list-style:none; }
.nav-menu a { font-size:15px; color:#2c4a2d; font-weight:500; transition:color .2s; }
.nav-menu a:hover { color:#6b8e5a; }
.nav-cta {
  background:#2c4a2d; color:#fff !important;
  padding:12px 24px; border-radius:30px;
  font-size:14px; font-weight:700; transition:all .2s;
}
.nav-cta:hover { background:#1f3520; transform:translateY(-1px); box-shadow:0 6px 18px rgba(44,74,45,0.3); }

/* ===== Hero ===== */
.hero {
  min-height:100vh; display:flex; align-items:center;
  background:linear-gradient(135deg, #1f3520 0%, #2c4a2d 50%, #3d5a3e 100%);
  color:#fff; padding-top:90px;
}
.hero-watermark {
  top:50%; left:50%; transform:translate(-50%, -50%);
  font-size:clamp(180px, 28vw, 420px);
  color:rgba(212,227,168,0.06);
  line-height:0.9; white-space:nowrap;
}
.hero::before {
  content:''; position:absolute; top:-100px; right:-100px;
  width:550px; height:550px;
  background:radial-gradient(circle, rgba(212,227,168,0.18) 0%, transparent 70%);
  border-radius:50%; z-index:1;
}
.hero::after {
  content:''; position:absolute; bottom:-200px; left:-200px;
  width:650px; height:650px;
  background:radial-gradient(circle, rgba(122,155,106,0.15) 0%, transparent 70%);
  border-radius:50%; z-index:1;
}
.hero-content { max-width:900px; position:relative; z-index:3; }
.hero-tagline { display:flex; align-items:center; gap:18px; margin-bottom:40px; }
.hero-tagline .line {
  width:60px; height:1px;
  background:linear-gradient(90deg, transparent 0%, #d4e3a8 100%);
}
.hero-tagline .text {
  font-family:'Cormorant Garamond', serif;
  font-size:18px; letter-spacing:8px;
  color:#d4e3a8; font-weight:300;
  font-style:italic; text-transform:uppercase;
}
.hero-tagline .text strong { font-weight:500; letter-spacing:8px; }
.hero h1 {
  font-family:'Gowun Batang', serif; font-size:64px;
  font-weight:700; line-height:1.5; margin-bottom:44px;
  color:#fff; letter-spacing:-1.5px;
}
.hero h1 .accent { color:#d4e3a8; position:relative; display:inline-block; }
.hero h1 .accent::after {
  content:''; position:absolute; left:0; right:0; bottom:-6px;
  height:5px; background:#d4e3a8; border-radius:3px;
}
.hero-sub {
  font-family:'Noto Sans KR', sans-serif;
  font-size:19px; color:#e8efd9;
  margin-bottom:50px; line-height:2.1; font-weight:300;
}
.hero-sub strong { color:#fff; font-weight:700; }
.cta-group { display:flex; gap:16px; flex-wrap:wrap; }
.btn {
  padding:18px 38px; border-radius:35px;
  font-size:15px; font-weight:700;
  transition:all .25s; cursor:pointer; border:none;
  display:inline-block; letter-spacing:0.5px;
  font-family:'Noto Sans KR', sans-serif;
}
.btn-primary { background:#fff; color:#2c4a2d; }
.btn-primary:hover { background:#d4e3a8; transform:translateY(-3px); box-shadow:0 12px 28px rgba(0,0,0,0.25); }
.btn-outline { background:transparent; color:#fff; border:2px solid #fff; }
.btn-outline:hover { background:#fff; color:#2c4a2d; transform:translateY(-3px); }

/* ===== Empathy ===== */
.empathy { background:#fff; }
.empathy-watermark {
  top:50px; right:-40px; font-size:clamp(120px, 18vw, 240px);
  color:rgba(122,155,106,0.06); line-height:1;
}
.empathy .section-label { background:#eaf0dc; color:#3d5a3e; }
.empathy .section-title { color:#1f2a20; }
.empathy .section-desc { color:#4a5a4b; }

/* ===== Brand Intro (새로 추가) ===== */
.brand-intro {
  text-align:center;
  max-width:880px;
  margin:0 auto 100px;
  padding:60px 40px 70px;
  background:linear-gradient(180deg, #fafbf4 0%, #f1f5e4 100%);
  border-radius:24px;
  border:1px solid #e0e6d4;
  position:relative;
  box-shadow:0 10px 30px rgba(44,74,45,0.06);
}
.brand-intro::before {
  content:'';
  position:absolute;
  top:-1px; left:50%;
  transform:translateX(-50%);
  width:80px; height:4px;
  background:linear-gradient(90deg, #6b8e5a 0%, #d4e3a8 100%);
  border-radius:0 0 6px 6px;
}
.brand-intro-tag {
  display:inline-block;
  font-family:'Cormorant Garamond', serif;
  font-style:italic;
  font-size:14px;
  letter-spacing:4px;
  color:#6b8e5a;
  background:#fff;
  padding:8px 22px;
  border-radius:25px;
  border:1px solid #d8e4c0;
  margin-bottom:30px;
}
.brand-intro-tag strong {
  font-family:'Gowun Batang', serif;
  font-style:normal;
  font-weight:700;
  font-size:14px;
  color:#2c4a2d;
  letter-spacing:0;
  margin-right:6px;
}
.brand-intro-title {
  font-family:'Gowun Batang', serif;
  font-size:38px;
  font-weight:700;
  color:#1f3520;
  line-height:1.55;
  margin-bottom:28px;
  letter-spacing:-0.8px;
}
.brand-intro-title .accent {
  color:#3d5a3e;
  position:relative;
  display:inline-block;
}
.brand-intro-title .accent::after {
  content:'';
  position:absolute;
  left:0; right:0; bottom:2px;
  height:10px;
  background:rgba(212,227,168,0.55);
  z-index:-1;
  border-radius:3px;
}
.brand-intro-text {
  font-size:17px;
  color:#3d5a3e;
  line-height:2.05;
  max-width:720px;
  margin:0 auto;
}
.brand-intro-text strong {
  color:#1f3520;
  font-weight:700;
}
.brand-intro-divider {
  display:flex;
  align-items:center;
  justify-content:center;
  gap:14px;
  margin:26px auto 22px;
}
.brand-intro-divider .dot {
  width:6px; height:6px;
  background:#6b8e5a;
  border-radius:50%;
}
.brand-intro-divider .line {
  width:40px; height:1px;
  background:#a8c189;
}

.empathy-quotes {
  display:grid; grid-template-columns:repeat(auto-fit, minmax(310px, 1fr));
  gap:30px; margin-top:50px;
}
.quote-card {
  background:linear-gradient(180deg, #fdfdfa 0%, #f5f7ec 100%);
  padding:50px 36px 36px; border-radius:20px;
  border:1px solid #e0e6d4;
  color:#2c3e2d; font-size:16px;
  font-family:'Gowun Batang', serif; font-weight:400;
  line-height:1.95; position:relative; transition:all .35s;
  box-shadow:0 6px 20px rgba(44,74,45,0.06);
  overflow:hidden;
}
.quote-card::before {
  content:'❝';
  font-family:'Cormorant Garamond', serif;
  font-weight:700; font-size:80px;
  color:#a8c189; position:absolute;
  top:14px; left:24px; line-height:0.8; opacity:0.7;
}
.quote-card::after {
  content:'❞';
  font-family:'Cormorant Garamond', serif;
  font-weight:700; font-size:60px;
  color:#a8c189; position:absolute;
  bottom:-8px; right:24px; line-height:0.8; opacity:0.4;
}
.quote-card:hover {
  transform:translateY(-8px);
  box-shadow:0 20px 40px rgba(44,74,45,0.15);
  border-color:#a8c189;
}
.quote-card:hover::before { opacity:1; color:#6b8e5a; }
.quote-card .quote-text { position:relative; z-index:2; padding-top:20px; padding-left:6px; }
.empathy-conclusion {
  margin-top:70px; text-align:center;
  font-family:'Gowun Batang', serif;
  font-size:28px; color:#fff; font-weight:700;
  padding:54px 40px;
  background:linear-gradient(135deg, #2c4a2d 0%, #4a6a4b 100%);
  border-radius:22px; line-height:1.85;
  box-shadow:0 18px 45px rgba(44,74,45,0.28);
  letter-spacing:-0.5px;
}
.empathy-conclusion strong { color:#d4e3a8; }

/* ===== Solution / Venn (SVG 방식) ===== */
.solution {
  background:linear-gradient(180deg, #f7f0e4 0%, #ebe4cf 100%);
  text-align:center;
}
.solution-watermark {
  top:50%; left:50%; transform:translate(-50%, -50%);
  font-size:clamp(200px, 32vw, 480px);
  color:rgba(44,74,45,0.05); line-height:0.9; white-space:nowrap;
}
.solution .section-label { background:#fff; color:#3d5a3e; }
.solution .section-title { color:#1f2a20; }
.solution .section-desc { color:#3d5a3e; margin-left:auto; margin-right:auto; }

.venn-svg-wrap {
  width:100%;
  max-width:780px;
  margin:30px auto 30px;
  position:relative;
}
.venn-svg { width:100%; height:auto; display:block; }
.venn-svg .circle { mix-blend-mode:multiply; }
.venn-svg .circle-left   { fill:#d9dabc; opacity:0.7; }
.venn-svg .circle-right  { fill:#c8d8bf; opacity:0.7; }
.venn-svg .circle-bottom { fill:#bdc4a3; opacity:0.7; }
.venn-svg .text-dark {
  fill:#1f3520;
  font-family:'Gowun Batang', serif;
  font-size:38px; font-weight:700;
  text-anchor:middle;
}
.venn-svg .text-white {
  fill:#ffffff;
  font-family:'Gowun Batang', serif;
  font-size:28px; font-weight:700;
  text-anchor:middle;
}
.venn-svg .text-accent {
  fill:#fffbd6;
  font-family:'Gowun Batang', serif;
  font-size:32px; font-weight:700;
  text-anchor:middle;
}

.solution-desc-bottom {
  max-width:740px; margin:40px auto 0;
  font-size:17px; color:#2c4a2d; line-height:2.1;
}
.solution-desc-bottom strong { color:#1f3520; font-weight:700; }

/* ===== Program ===== */
.program { background:#fff; }
.program-watermark {
  top:80px; left:-50px; font-size:clamp(150px, 22vw, 300px);
  color:rgba(44,74,45,0.05); line-height:1;
}
.program .section-label { background:#2c4a2d; color:#fff; }
.program-intro { display:grid; grid-template-columns:1fr 1fr; gap:30px; margin-bottom:90px; }
.program-axis {
  background:linear-gradient(135deg, #3d5a3e 0%, #2c4a2d 100%);
  color:#fff; padding:46px 38px; border-radius:22px;
  transition:all .3s; position:relative; overflow:hidden;
}
.program-axis::before {
  content:''; position:absolute; top:-60px; right:-60px;
  width:200px; height:200px;
  background:radial-gradient(circle, rgba(212,227,168,0.18) 0%, transparent 70%);
  border-radius:50%;
}
.program-axis:hover { transform:translateY(-10px); box-shadow:0 24px 45px rgba(44,74,45,0.28); }
.axis-num {
  font-family:'Playfair Display', serif;
  font-size:13px; color:#d4e3a8; letter-spacing:5px;
  margin-bottom:14px; font-weight:700;
}
.axis-title { font-size:28px; margin-bottom:10px; color:#fff; font-weight:700; line-height:1.4; }
.axis-en { font-family:'Playfair Display', serif; font-style:italic; color:#d4e3a8; font-size:15px; margin-bottom:22px; }
.axis-desc { color:#e8efd9; font-size:16px; line-height:1.95; }
.axis-desc strong { color:#fff; }

.concept-block { padding:58px 48px; border-radius:26px; margin-bottom:30px; border:2px solid #d8e4c0; }
.concept-block.lit { background:linear-gradient(135deg, #eaf0dc 0%, #f5f7ec 100%); }
.concept-block.nonfic { background:linear-gradient(135deg, #f5f7ec 0%, #eaf0dc 100%); }
.concept-block h3 {
  font-family:'Gowun Batang', serif; font-size:28px;
  margin-bottom:18px; color:#1f3520; font-weight:700;
  display:flex; align-items:center; gap:14px; line-height:1.4;
}
.concept-block h3::before { content:'🌿'; font-size:26px; }
.concept-intro { color:#3d5a3e; font-size:16px; margin-bottom:30px; line-height:2; }
.concept-intro strong { color:#1f3520; font-weight:700; }
.concept-words { display:flex; flex-wrap:wrap; gap:12px; margin-bottom:28px; }
.concept-word {
  background:#fff; color:#2c4a2d;
  padding:12px 24px; border-radius:25px;
  font-size:15px; font-weight:700;
  border:2px solid #6b8e5a; transition:all .2s;
}
.concept-word.more { background:#2c4a2d; color:#fff; border-color:#2c4a2d; }
.concept-note {
  font-size:14px; color:#5e6e5f; font-style:italic;
  padding-top:20px; border-top:1px dashed #c5d4b5; line-height:1.8;
}

.steps-title-wrap { margin-top:60px; margin-bottom:18px; }
.steps-title { font-family:'Gowun Batang', serif; font-size:30px; color:#1f3520; font-weight:700; line-height:1.5; }
.steps-sub { color:#5e6e5f; font-size:16px; margin-bottom:36px; line-height:1.85; }
.steps-grid { display:grid; grid-template-columns:repeat(auto-fit, minmax(240px, 1fr)); gap:20px; }
.step-card { background:#fff; padding:32px 28px; border-radius:18px; border:2px solid #eef1e4; transition:all .25s; }
.step-card:hover { transform:translateY(-7px); border-color:#6b8e5a; box-shadow:0 14px 32px rgba(107,142,90,0.22); }
.step-num {
  width:46px; height:46px; border-radius:50%;
  background:linear-gradient(135deg, #6b8e5a 0%, #3d5a3e 100%);
  color:#fff; display:flex; align-items:center; justify-content:center;
  font-family:'Playfair Display', serif; font-weight:900;
  font-size:19px; margin-bottom:18px;
  box-shadow:0 4px 12px rgba(107,142,90,0.35);
}
.step-title { font-family:'Gowun Batang', serif; font-size:19px; font-weight:700; color:#1f3520; margin-bottom:10px; line-height:1.4; }
.step-desc { font-size:14.5px; color:#4a5a4b; line-height:1.8; }
.outputs {
  background:linear-gradient(135deg, #2c4a2d 0%, #3d5a3e 100%);
  color:#fff; padding:50px 44px; border-radius:22px; margin-top:70px;
}
.outputs h4 { font-family:'Gowun Batang', serif; font-size:24px; margin-bottom:26px; color:#fff; font-weight:700; }
.outputs-list { display:flex; flex-wrap:wrap; gap:12px; }
.output-tag {
  background:rgba(255,255,255,0.15); backdrop-filter:blur(4px);
  padding:11px 22px; border-radius:22px;
  font-size:14.5px; color:#fff; font-weight:500;
  border:1.5px solid rgba(212,227,168,0.5);
}

/* ===== Level ===== */
.level { background:linear-gradient(180deg, #d8e4c0 0%, #c5d4b5 100%); }
.level-watermark {
  top:50%; right:-60px; transform:translateY(-50%);
  font-size:clamp(150px, 22vw, 320px);
  color:rgba(31,53,32,0.06); line-height:1;
}
.level .section-label { background:#2c4a2d; color:#fff; }
.level .section-title { color:#1f3520; }
.level .section-desc { color:#2c4a2d; }
.level-table {
  background:#fff; border-radius:22px; overflow:hidden;
  box-shadow:0 12px 45px rgba(44,74,45,0.18); margin-bottom:46px;
}
.level-row {
  display:grid; grid-template-columns:130px 210px 1fr;
  padding:28px 38px; border-bottom:1px solid #eef1e4;
  align-items:center; transition:background .2s;
}
.level-row:hover { background:#fafaf5; }
.level-row:last-child { border-bottom:none; }
.level-row.head {
  background:linear-gradient(135deg, #2c4a2d 0%, #3d5a3e 100%);
  color:#fff; font-family:'Gowun Batang', serif; font-weight:700;
}
.level-row.head:hover { background:linear-gradient(135deg, #2c4a2d 0%, #3d5a3e 100%); }
.level-badge {
  width:60px; height:60px; border-radius:50%;
  color:#fff; font-family:'Playfair Display', serif; font-weight:900;
  font-size:18px; display:flex; align-items:center; justify-content:center;
  box-shadow:0 4px 14px rgba(0,0,0,0.18);
}
.level-row.head .level-badge { background:transparent !important; border:2px solid #fff; box-shadow:none; }
.badge-L1 { background:linear-gradient(135deg, #b8d49a 0%, #a0c47e 100%); color:#1f3520; }
.badge-L2 { background:linear-gradient(135deg, #8cb473 0%, #6b9a55 100%); }
.badge-L3 { background:linear-gradient(135deg, #6b8e5a 0%, #4a7041 100%); }
.badge-L4 { background:linear-gradient(135deg, #4a6a4b 0%, #2c4a2d 100%); }
.badge-L5 { background:linear-gradient(135deg, #2c4a2d 0%, #0f1f10 100%); }
.level-name { font-family:'Gowun Batang', serif; font-weight:700; font-size:19px; color:#1f3520; line-height:1.4; }
.level-row.head .level-name { color:#fff; }
.level-goal { font-size:16px; color:#3d5a3e; font-weight:500; line-height:1.7; }
.level-row.head .level-goal { color:#fff; font-weight:700; }
.level-note {
  text-align:center; color:#1f3520; font-size:16px;
  background:rgba(255,255,255,0.75); padding:24px 32px;
  border-radius:14px; font-weight:500; line-height:1.85;
}
.level-note a { color:#2c4a2d; font-weight:700; border-bottom:2px solid #2c4a2d; }

/* ===== FAQ ===== */
.faq { background:#1f3520; color:#fff; }
.faq-watermark {
  top:50%; left:50%; transform:translate(-50%, -50%);
  font-size:clamp(200px, 32vw, 460px);
  color:rgba(212,227,168,0.04); line-height:0.9; white-space:nowrap;
}
.faq .section-label { background:#d4e3a8; color:#1f3520; }
.faq .section-title { color:#fff; }
.faq .section-desc { color:#c5d4b5; }
.faq-list { max-width:920px; margin:0 auto; }
.faq-item {
  background:rgba(255,255,255,0.05);
  border:1.5px solid rgba(212,227,168,0.2);
  border-radius:16px; margin-bottom:16px;
  overflow:hidden; transition:all .25s;
}
.faq-item:hover { background:rgba(255,255,255,0.09); border-color:rgba(212,227,168,0.4); }
.faq-q {
  display:flex; align-items:flex-start; gap:20px;
  font-family:'Gowun Batang', serif;
  font-size:18.5px; font-weight:700; color:#fff;
  line-height:1.65; padding:26px 32px;
  cursor:pointer; user-select:none;
}
.faq-q-icon {
  flex-shrink:0; width:36px; height:36px;
  border-radius:50%; background:#d4e3a8; color:#1f3520;
  display:flex; align-items:center; justify-content:center;
  font-size:15px; font-weight:900;
  font-family:'Playfair Display', serif;
}
.faq-q-text { flex:1; }
.faq-toggle {
  margin-left:auto; font-size:28px; color:#d4e3a8;
  transition:transform .3s; flex-shrink:0;
  font-weight:300; line-height:1;
}
.faq-item.open .faq-toggle { transform:rotate(45deg); }
.faq-a-wrap { max-height:0; overflow:hidden; transition:max-height .4s ease; }
